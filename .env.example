# ── LLM ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_PASSWORD=your_neo4j_password_here

# ── CLIP Service ───────────────────────────────────────────────────────────────
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=openai

# ── Docker build ───────────────────────────────────────────────────────────────
# Controls which PyTorch wheel is installed in the base image at build time.
#   auto  — detects NVIDIA GPU via nvidia-smi; falls back to CPU (default)
#   cpu   — force CPU-only wheel (~250 MB, no CUDA deps)
#   cuda  — force CUDA wheel (~1.5 GB, full nvidia stack)
#
# Note: "auto" requires the NVIDIA Container Toolkit for GPU detection inside
# Docker. Without it, even a GPU machine resolves to "cpu" — set cuda explicitly.
# Mac (Apple Silicon): Docker runs a Linux VM, MPS is unavailable, "auto" → "cpu".
TORCH_DEVICE=auto

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
