# ── Runtime service endpoints (must be running before pipeline) ────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

QDRANT_URL=http://localhost:6333
CLIP_SERVICE_URL=http://localhost:8001

# ── Scraper settings ───────────────────────────────────────────────────────────
# SCRAPE_TARGET: all | characters | games | enemies | locations | organizations | timeline
SCRAPE_TARGET=all
RATE_LIMIT_DELAY=2.0
MAX_PAGES=500

# ── Ingestor settings ──────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
